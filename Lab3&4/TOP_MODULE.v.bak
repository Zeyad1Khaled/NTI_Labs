module TOP_MODULE #(parameter WIDTH=20,Addr_width=8,ALU_OUT=8)(
  input clk,rst_n,wr_en,
  input [Addr_width-1:0] addr,
  input [WIDTH-1:0] din,
  
  output [ALU_OUT-1:0] out,
  output a_is_zero
);
//ALU Wire
wire [WIDTH-1:0] parallel_out;
//RAM Wire
wire [WIDTH-1:0] ram_dout;
wire ram_valid;
//PISO wire
wire PISO_out;
wire en;
wire PISO_valid;
wire [Addr_width-1:0] piso_addr;

RAM U1(
.clk(clk),
.rst_n(rst_n),
.wr_en(wr_en),
.addr(wr_en ? addr : piso_addr),
.din(din),
.rd_en(en),
.dout(ram_dout),
.valid(ram_valid));

PISO U2 (
.clk(clk),
.parallel_in(ram_dout),
.rst_n(rst_n),
.ram_valid(ram_valid),
.serial_out(PISO_out),
.en(en),
.valid(PISO_valid)
.addr(piso_addr));

SIPO U3(
.clk(clk),
.rst_n(rst_n),
.shift_en(PISO_valid),
.serial_in(PISO_out),
.parallel_out(parallel_out));

ALU U4 (
.alu_en(parallel_out[19]),
.opcode(parallel_out[18:16]),
.in_a(parallel_out[15:8]),
.in_b(parallel_out[7:0]),
.alu_out(out),
.a_is_zero(a_is_zero)
);
endmodule