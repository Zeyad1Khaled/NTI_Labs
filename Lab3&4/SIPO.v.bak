module SIPO#(parameter WIDTH=20)(
  
  input wire clk,
  input wire shift_en,rst_n,serial_in,
  
  //ALU INputs
  input alu_en,
  input [WIDTH-18:0] opcode,
  input [WIDTH-12:0] in_A,in_b,
  
  output reg [WIDTH-1:0] parallel_out
);

always@(posedge clk or negedge rst_n)begin
  if(!rst_n)
      parallel_out<= {WIDTH{1'b0}};
  
  else if (shift_en)begin
		parallel_out<={parallel_out[WIDTH-2:0],serial_in};
  end
  
end

assign alu_en=parallel_out[19];
assign opcode=parallel_out[18:16];
assign in_a=parallel_out[15:8];
assign in_b=parallel_out[7:0];
endmodule

